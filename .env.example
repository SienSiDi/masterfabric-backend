# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT_SECONDS=15
SERVER_WRITE_TIMEOUT_SECONDS=15
SERVER_IDLE_TIMEOUT_SECONDS=60

# Postgres
DATABASE_DSN=postgres://masterfabric:masterfabric@localhost:5432/masterfabric?sslmode=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DB_SSLMODE=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT (change the secret before any non-local deploy)
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_HOURS=168

# HTTP
CORS_ALLOWED_ORIGINS=
MAX_BODY_BYTES=1048576

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
